# ============================================
# Unity 6 .gitignore
# ============================================

# Unity generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/
/[Mm]emoryCaptures/

# Asset Store Tools
/Assets/AssetStoreTools*

# Plastic SCM (legacy - migrated to Git)
/Assets/Plugins/PlasticSCM*
/.plastic/

# Autogenerated VS/Rider solution files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity meta files for above
*.pidb.meta
*.pdb.meta
*.mdb.meta

# OS generated
.DS_Store*
Thumbs.db
Desktop.ini

# IDE
.vs/
.vscode/
.idea/
.gradle/
.consulo/
ExportedObj/

# Unity build outputs
*.apk
*.aab
*.app
*.unitypackage

# Unity misc
sysinfo.txt
crashlytics-build.properties
~UnityDirMonSyncFile~*

# Addressable Assets
/Assets/AddressableAssetsData/*/*.bin*
/Assets/StreamingAssets/aa.meta
/Assets/StreamingAssets/*/aa/*

# Private / sensitive files
*.private
*.private.meta

# Plastic SCM ignore config (no longer needed with Git)
ignore.conf
